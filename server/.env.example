# Copy to .env and fill in your key:
# cp .env.example .env

# --- LLM (pick one) ---
# Recommended for free tier: Groq (OpenAI-compatible). Keys: https://console.groq.com/keys
# If GROQ_API_KEY is set, it is used before OPENAI_API_KEY.
GROQ_API_KEY=gsk_...
# Optional Groq model (default: llama-3.1-8b-instant). See https://console.groq.com/docs/models
# GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (paid) or any OpenAI-compatible server with base URL:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.example.com/v1

# Optional: port (default: 5001)
# PORT=5001

# Optional: IEMOCAP-based emotion API (voice + text emotion). Run ml/app.py on port 5002.
# EMOTION_API_URL=http://localhost:5002
