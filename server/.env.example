# Copy to .env and fill in your key:
# cp .env.example .env

# Required for LLM responses (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Optional: model name (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: port (default: 5001)
# PORT=5001

# Optional: IEMOCAP-based emotion API (voice + text emotion). Run ml/app.py on port 5002.
# EMOTION_API_URL=http://localhost:5002
